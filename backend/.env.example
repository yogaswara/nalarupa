NODE_ENV=development
PORT=5011
DATABASE_URL=sqlite://./data/nalarupa.db
GEMINI_API_KEY=

# AI Configuration (Options: gemini, pollinations)
# Default is gemini if GEMINI_API_KEY is set, otherwise falls back to pollinations.
AI_PROVIDER=pollinations

# Pollinations Configuration (Optional)
POLLINATIONS_API_URL=https://image.pollinations.ai/prompt/
POLLINATIONS_API_KEY=
POLLINATIONS_IMAGE_MODEL=flux
POLLINATIONS_IMAGE_WIDTH=512
POLLINATIONS_IMAGE_HEIGHT=512

# Performance Controls
AI_TASK_TIMEOUT_MS=28000
AI_PROVIDER_TIMEOUT_MS=26000
AI_TEXT_TIMEOUT_MS=8000
AI_OPTIMIZATION_THRESHOLD=450
